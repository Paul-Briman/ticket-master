JWT_SECRET=replace-with-a-long-random-string-min-32-chars
RESEND_API_KEY=
EMAIL_FROM=ticketmaster <onboarding@resend.dev>
APP_URL=http://localhost:5173
ADMIN_EMAIL=admin@ticket.com
ADMIN_PASSWORD=123456

# Optional: Google Sign-In. Get a Web Client ID from:
# https://console.cloud.google.com/apis/credentials
# Add http://localhost:5173 and your Vercel URL as Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=

# Optional: TheSportsDB API key. The free public key "3" works without setting
# this. Set this only if you have a Patreon-tier key for richer data.
# Docs: https://www.thesportsdb.com/api.php
SPORTDB_API_KEY=
