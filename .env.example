JWT_SECRET=replace-with-a-long-random-string-min-32-chars
RESEND_API_KEY=

# Production sender. Must use a Resend-verified domain (Resend dashboard
# → Domains → Verified). The mailbox portion is purely cosmetic for
# delivery — pick noreply@ for automated mail.
EMAIL_FROM=Ticketsmasterr <noreply@ticketsmasterr.com>

# Optional. When set, every automated email includes a Reply-To header
# so customer replies reach a monitored inbox instead of the unattended
# noreply mailbox. Leave blank to omit the header.
SUPPORT_EMAIL=support@ticketsmasterr.com

# Public site URL. Used in email templates (verification + reset links)
# and shown as the canonical origin. Set this to your production host on
# Vercel; localhost is fine for dev.
APP_URL=https://ticketsmasterr.com

ADMIN_EMAIL=admin@ticket.com
ADMIN_PASSWORD=123456

# Optional: Google Sign-In. Get a Web Client ID from:
# https://console.cloud.google.com/apis/credentials
# Add http://localhost:5173 and your Vercel URL as Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=

# Optional: TheSportsDB API key. The free public key "3" works without setting
# this. Set this only if you have a Patreon-tier key for richer data.
# Docs: https://www.thesportsdb.com/api.php
SPORTDB_API_KEY=

# football-data.org Auth Token (X-Auth-Token header).
# Free tier covers the major competitions (CL, WC, EPL, etc.) with a
# 10 req/min rate limit. Sign up: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Bandsintown public app id (no secret). Used for live concert data.
# Convention: any short identifier string. https://artists.bandsintown.com/support/bandsintown-api
BANDSINTOWN_APP_ID=ticketmaster-clone
